# ─────────────────────────────────────────────────────────────
# WeaveAI — 部署环境变量模板
# 复制为 .env 后按实际情况填写
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── 域名（nginx / certbot 使用；不带 http:// 前缀，不带尾斜杠） ──
# 例：example.com  （证书会同时申请 www.example.com）
DOMAIN=example.com

# ── Let's Encrypt 邮箱（用于证书过期提醒） ──
CERTBOT_EMAIL=admin@example.com

# ── 是否使用 Let's Encrypt staging 环境（1 = 测试，0 = 正式） ──
# 首次调试时建议置 1，避免触发速率限制
CERTBOT_STAGING=0

# ── OpenAI / Deepseek 兼容 API（前端不传 config 时的后备值） ──
# 若前端始终携带 config，可留空
OPENAI_API_KEY=
